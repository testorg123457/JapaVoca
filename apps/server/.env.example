# Copy to .env and fill in real values. Do NOT commit .env.

# --- Django core ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
# Set DB_ENGINE=sqlite for local dev without a running Postgres.
DB_ENGINE=postgresql
DB_NAME=japavoca
DB_USER=root
DB_PASSWORD=1234
DB_HOST=127.0.0.1
DB_PORT=5432

# --- CORS ---
# Comma-separated allowed origins. Leave empty to allow all in DEBUG.
CORS_ALLOWED_ORIGINS=

# --- Celery (배치 스케줄러) ---
# 브로커. 로컬 Redis 기본값. 미설치 시 `brew install redis && brew services start redis`.
CELERY_BROKER_URL=redis://localhost:6379/0

# --- Google OAuth (social login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AdMob ---
ADMOB_APP_ID=
ADMOB_REWARDED_UNIT_ID=
# SSV 서명 검증: false(dev)면 Mock(검증 스킵), true면 실제 서명 검증.
ADMOB_SSV_VERIFY=false

# --- Gifticon / exchange 발급사 ---
# URL 이 비어있으면 exchange.providers 가 Mock 발급(개발용)으로 동작.
GIFTICON_PROVIDER_URL=
GIFTICON_PROVIDER_KEY=
